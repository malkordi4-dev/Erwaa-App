<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:layoutDirection="rtl">

    <RelativeLayout
        android:id="@+id/layoutHeaderProfile"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            app:cardCornerRadius="19dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/user"
                android:scaleType="centerCrop" />
        </com.google.android.material.card.MaterialCardView>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:src="@drawable/notification"
            app:tint="#0069B4" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/layoutHeaderProfile"
        app:layout_constraintBottom_toTopOf="@id/bottomNavProfile">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="20dp">

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardProfileImage"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    app:cardCornerRadius="60dp"
                    app:cardElevation="4dp"
                    app:strokeWidth="4dp"
                    app:strokeColor="#FFFFFF">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/user"
                        android:scaleType="centerCrop" />
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_alignBottom="@id/cardProfileImage"
                    android:layout_alignLeft="@id/cardProfileImage"
                    android:layout_marginBottom="4dp"
                    app:cardBackgroundColor="#0069B4"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="6dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:src="@drawable/pen"
                        app:tint="#FFFFFF" />
                </com.google.android.material.card.MaterialCardView>
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="محمد أحمد الفلسطيني"
                android:textColor="#1E293B"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="معرف المستخدم: #ERW-77421"
                android:textColor="#64748B"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="32dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp"
                    app:strokeColor="#E2E8F0"
                    app:strokeWidth="1dp">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp">
                        <ImageView android:id="@+id/i1" android:layout_width="24dp" android:layout_height="24dp" android:layout_alignParentRight="true" android:src="@drawable/wallet" app:tint="#0069B4"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toLeftOf="@id/i1" android:layout_marginRight="12dp" android:text="المحفظة الإلكترونية" android:textColor="#1E293B" android:textSize="15sp" android:layout_centerVertical="true"/>
                        <ImageView android:layout_width="18dp" android:layout_height="18dp" android:layout_alignParentLeft="true" android:src="@drawable/ic_chevron_left" app:tint="#CBD5E1"/>
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp"
                    app:strokeColor="#E2E8F0"
                    app:strokeWidth="1dp">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp">

                        <ImageView
                            android:id="@+id/i2"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_alignParentRight="true"
                            android:src="@drawable/question"
                            app:tint="#0069B4" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toLeftOf="@id/i2" android:layout_marginRight="12dp" android:text=" المساعدة والدعم" android:textColor="#1E293B" android:textSize="15sp" android:layout_centerVertical="true"/>
                        <ImageView android:layout_width="18dp" android:layout_height="18dp" android:layout_alignParentLeft="true" android:src="@drawable/ic_chevron_left" app:tint="#CBD5E1"/>
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp"
                    app:strokeColor="#E2E8F0"
                    app:strokeWidth="1dp">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp">
                        <ImageView android:id="@+id/i3" android:layout_width="24dp" android:layout_height="24dp" android:layout_alignParentRight="true" android:src="@drawable/data" app:tint="#0069B4"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toLeftOf="@id/i3" android:layout_marginRight="12dp" android:text="كلمة المرور والأمان" android:textColor="#1E293B" android:textSize="15sp" android:layout_centerVertical="true"/>
                        <ImageView android:layout_width="18dp" android:layout_height="18dp" android:layout_alignParentLeft="true" android:src="@drawable/ic_chevron_left" app:tint="#CBD5E1"/>
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp"
                    app:strokeColor="#E2E8F0"
                    app:strokeWidth="1dp">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp">
                        <ImageView android:id="@+id/i4" android:layout_width="24dp" android:layout_height="24dp" android:layout_alignParentRight="true" android:src="@drawable/language" app:tint="#0069B4"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toLeftOf="@id/i4" android:layout_marginRight="12dp" android:text="لغة التطبيق (العربية)" android:textColor="#1E293B" android:textSize="15sp" android:layout_centerVertical="true"/>
                        <ImageView android:layout_width="18dp" android:layout_height="18dp" android:layout_alignParentLeft="true" android:src="@drawable/ic_chevron_left" app:tint="#CBD5E1"/>
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#FCA5A5"
                    app:strokeWidth="1.5dp"
                    app:cardBackgroundColor="#FEF2F2">
                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp">
                        <ImageView android:id="@+id/iLogout" android:layout_width="24dp" android:layout_height="24dp" android:layout_alignParentRight="true" android:src="@drawable/logout" app:tint="#DC2626"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_toLeftOf="@id/iLogout" android:layout_marginRight="12dp" android:text="تسجيل الخروج" android:textColor="#DC2626" android:textSize="15sp" android:textStyle="bold" android:layout_centerVertical="true"/>
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomNavOrders"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:strokeColor="#E2E8F0"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/user"
                app:tint="#0069B4"
                />
            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="حسابي"
                android:textColor="#0069B4"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="21dp"
                android:src="@drawable/wallet"
                app:tint="#94A3B8" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="المحفظة"
                android:textColor="#94A3B8"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/personal"
                app:tint="#94A3B8" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="طلباتي"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/home"
                app:tint="#94A3B8" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="الرئيسية"
                android:textColor="#94A3B8"
                android:textSize="11sp" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

