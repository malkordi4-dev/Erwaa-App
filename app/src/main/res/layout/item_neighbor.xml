<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#F8FAFC">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvNeighborName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:text="اسم الجار"
            android:textColor="#1E293B"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvNeighborQuantity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvNeighborName"
            android:layout_alignParentRight="true"
            android:layout_marginTop="2dp"
            android:text="200 لتر"
            android:textColor="#64748B"
            android:textSize="12sp" />

        <ImageView
            android:id="@+id/btnRemoveNeighbor"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#EF4444" />
    </RelativeLayout>
</androidx.cardview.widget.CardView>