<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:layoutDirection="rtl">

    <RelativeLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvStepIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:text="خطوة 3 من 3"
            android:textColor="#64748B"
            android:textSize="12sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="مراجعة الطلب"
            android:textColor="#0069B4"
            android:textSize="18sp" />

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:src="@drawable/back"
            app:tint="#555555" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader"
        app:layout_constraintBottom_toTopOf="@id/layoutFooterPrice">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/img8"
                        android:scaleType="centerCrop" />
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#30000000"/>
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_alignParentRight="true"
                        android:layout_bottomOf="parent"
                        android:layout_margin="16dp"
                        android:layout_marginTop="50sp"
                        android:gravity="right">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="الخدمة المختارة"
                            android:textColor="#E2E8F0"

                            android:textSize="11sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="توصيل مياه صالحة للشرب"
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="14dp"
                app:cardElevation="0.5dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/ivProviderIcon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentRight="true"
                        android:src="@drawable/ic_store"
                        app:tint="#0D63B3" />

                    <TextView
                        android:id="@+id/tvProviderTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toLeftOf="@id/ivProviderIcon"
                        android:layout_marginRight="8dp"
                        android:text="المزود"
                        android:textColor="#0D63B3"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvProviderName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tvProviderTitle"
                        android:layout_alignParentRight="true"
                        android:layout_marginTop="8dp"
                        android:text="محطة غزة المركزية للتحلية"
                        android:textColor="#1E293B"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvProviderRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tvProviderName"
                        android:layout_alignParentRight="true"
                        android:layout_marginTop="4dp"
                        android:text="⭐ 4.8 (+120)"
                        android:textColor="#64748B"
                        android:textSize="13sp" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#E0F2FE"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/ivTimeIcon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentRight="true"
                        android:src="@drawable/ic_time"
                        app:tint="#0369A1" />

                    <TextView
                        android:id="@+id/tvTimeTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toLeftOf="@id/ivTimeIcon"
                        android:layout_marginRight="8dp"
                        android:text="وقت الوصول المتوقع"
                        android:textColor="#0369A1"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvDeliveryTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tvTimeTitle"
                        android:layout_alignParentRight="true"
                        android:layout_marginTop="6dp"
                        android:text="45 دقيقة"
                        android:textColor="#0369A1"
                        android:textSize="18sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tvDeliveryTime"
                        android:layout_alignParentRight="true"
                        android:layout_marginTop="2dp"
                        android:text="توصيل مباشر إلى موقعك"
                        android:textColor="#0284C7"
                        android:textSize="12sp" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="14dp"
                app:cardElevation="0.5dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <ImageView
                            android:id="@+id/ivLocIcon"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentRight="true"
                            android:src="@drawable/ic_location"
                            app:tint="#0D63B3" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_toLeftOf="@id/ivLocIcon"
                            android:layout_marginRight="8dp"
                            android:text="موقع التوصيل"
                            android:textColor="#0D63B3"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/btnEditLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentLeft="true"
                            android:text="تعديل"
                            android:textColor="#0069B4"
                            android:textSize="13sp"
                            android:clickable="true"
                            android:focusable="true"/>
                    </RelativeLayout>

                    <TextView
                        android:id="@+id/tvLocationMain"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="حي الرمال، شارع الجلاء، بالقرب من المسجد الكبير"
                        android:textColor="#1E293B"
                        android:textSize="14sp"
                        android:layout_marginTop="8dp"
                        android:gravity="right" />

                    <TextView
                        android:id="@+id/tvLocationSub"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="غزة، فلسطين"
                        android:textColor="#94A3B8"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp"
                        android:gravity="right" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:layout_marginTop="12dp"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0dp">
                        <com.google.android.gms.maps.MapView
                            android:id="@+id/mapViewReview"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="14dp"
                app:cardElevation="0.5dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="تفاصيل الطلب"
                        android:textColor="#64748B"
                        android:textSize="13sp"
                        android:layout_marginBottom="12dp"
                        android:gravity="right"/>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentRight="true"
                            android:text="مياه عذبة (500 لتر)"
                            android:textColor="#1E293B"
                            android:textSize="14sp"/>
                        <TextView
                            android:id="@+id/tvWaterPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentLeft="true"
                            android:text="50.00 ILS"
                            android:textColor="#1E293B"
                            android:textSize="14sp"/>
                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentRight="true"
                            android:text="رسوم التوصيل"
                            android:textColor="#1E293B"
                            android:textSize="14sp"/>
                        <TextView
                            android:id="@+id/tvDeliveryPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentLeft="true"
                            android:text="10.00 ILS"
                            android:textColor="#1E293B"
                            android:textSize="14sp"/>
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E2E8F0"
                        android:layout_marginBottom="12dp"/>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_alignParentRight="true">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="الإجمالي التقديري"
                                android:textColor="#1E293B"
                                android:textSize="16sp"
                                android:textStyle="bold"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="شامل كافة الرسوم والضرائب"
                                android:textColor="#94A3B8"
                                android:textSize="11sp"
                                android:layout_marginTop="2dp"/>
                        </LinearLayout>
                        <TextView
                            android:id="@+id/tvTotalPriceMain"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentLeft="true"
                            android:layout_centerVertical="true"
                            android:text="60.00 ILS"
                            android:textColor="#0069B4"
                            android:textSize="18sp"
                            android:textStyle="bold"/>
                    </RelativeLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🛡️ دفع آمن وخدمة مضمونة من Hydro-Vitality"
                android:textColor="#94A3B8"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginBottom="8dp"/>
        </LinearLayout>
    </ScrollView>

    <RelativeLayout
        android:id="@+id/layoutFooterPrice"
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:background="#FFFFFF"
        android:paddingHorizontal="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="المبلغ الإجمالي"
                android:textColor="#94A3B8"
                android:textSize="11sp" />
            <TextView
                android:id="@+id/tvFooterPriceText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="60.00 ILS"
                android:textColor="#0069B4"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnConfirmAndSend"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:text="تأكيد وإرسال الطلب  ➤"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:backgroundTint="#005B8A"
            app:cornerRadius="12dp"/>
    </RelativeLayout>

</androidx.constraintlayout.widget.ConstraintLayout>