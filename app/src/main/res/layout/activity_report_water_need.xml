<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:layoutDirection="rtl">

    <RelativeLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#FFFFFF"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:src="@drawable/back"
            app:tint="#0A3A60" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toLeftOf="@id/btnBack"
            android:layout_marginRight="12dp"
            android:layout_centerVertical="true"
            android:text="إبلاغ عن احتياج مياه"
            android:textColor="#1E293B"
            android:textSize="18sp"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/user"
                android:scaleType="centerCrop" />
        </com.google.android.material.card.MaterialCardView>
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader"
        app:layout_constraintBottom_toTopOf="@id/btnSubmitReport">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="تحديد الموقع على الخريطة"
                android:textColor="#475569"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#E2E8F0"
                app:strokeWidth="1dp">

                <fragment
                    android:id="@+id/mapReportLocation"
                    android:name="com.google.android.gms.maps.SupportMapFragment"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    tools:context=".ReportNeedActivity" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="اسم الحي"
                android:textColor="#475569"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/etDistrictName"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_edit_text"
                android:hint="مثال: حي الرمال"
                android:textColorHint="#94A3B8"
                android:textColor="#1E293B"
                android:textSize="14sp"
                android:paddingHorizontal="16dp"
                android:gravity="right|center_vertical"
                android:inputType="text"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="عدد العائلات المتضررة"
                android:textColor="#475569"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/etAffectedFamilies"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_edit_text"
                android:hint="0"
                android:textColorHint="#94A3B8"
                android:textColor="#1E293B"
                android:textSize="14sp"
                android:paddingHorizontal="16dp"
                android:gravity="right|center_vertical"
                android:inputType="number"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="مستوى الاحتياج"
                android:textColor="#475569"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/btnStatusStable"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_status_inactive"
                    android:text="مستقر"
                    android:textColor="#475569"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:layout_marginLeft="6dp"/>

                <TextView
                    android:id="@+id/btnStatusMedium"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_status_inactive"
                    android:text="متوسط"
                    android:textColor="#475569"
                    android:gravity="center"
                    android:textSize="14sp"
                    android:layout_marginLeft="6dp"/>

                <TextView
                    android:id="@+id/btnStatusCritical"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_status_critical"
                    android:text="حرج"
                    android:textColor="#DC2626"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textSize="14sp"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ملاحظات إضافية"
                android:textColor="#475569"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/etAdditionalNotes"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="@drawable/bg_edit_text"
                android:hint="اكتب تفاصيل إضافية هنا..."
                android:textColorHint="#94A3B8"
                android:textColor="#1E293B"
                android:textSize="14sp"
                android:padding="16dp"
                android:gravity="top|right"
                android:inputType="textMultiLine"
                android:layout_marginBottom="16dp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSubmitReport"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="20dp"
        android:text="إرسال البلاغ"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#003B73"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>