<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <RelativeLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="@font/cairo_black"
            android:text="إرواء"
            android:textColor="#0069B4"
            android:textSize="18sp" />

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:src="@drawable/back"
            app:tint="#555555" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingBottom="32dp">

            <LinearLayout
                android:id="@+id/layoutLogo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">


                <androidx.cardview.widget.CardView
                    android:id="@+id/cardLogo"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    app:cardCornerRadius="20dp"
                    app:cardBackgroundColor="#0069B4"
                    app:cardElevation="0dp"
                    android:layout_marginTop="16dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_water_drop"
                        android:layout_gravity="center"
                        app:tint="#FFFFFF" />
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="تعيين كلمة مرور جديدة"
                android:textColor="#111111"
                android:textSize="20sp"
                android:fontFamily="@font/cairo_black"
                android:layout_marginTop="28dp"
                app:layout_constraintTop_toBottomOf="@id/layoutLogo"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tvSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="الرجاء إدخال كلمة المرور الجديدة وتأكيدها لحماية حسابك."
                android:textColor="#666666"
                android:textSize="13sp"
                android:fontFamily="@font/cairo_regular"
                android:layout_marginTop="6dp"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/tvTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardForm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardElevation="2dp"
                app:layout_constraintTop_toBottomOf="@id/tvSub">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="كلمة المرور الجديدة"
                        android:textColor="#333333"
                        android:textSize="14sp"
                        android:fontFamily="@font/cairo_black"
                        android:gravity="right" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_otp_box"
                        android:paddingHorizontal="12dp">

                        <ImageView
                            android:id="@+id/ivLockNew"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_lock"
                            app:tint="#888888" />

                        <EditText
                            android:id="@+id/etNewPassword"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_toLeftOf="@id/ivLockNew"
                            android:layout_toRightOf="@+id/ivVisibilityNew"
                            android:background="@null"
                            android:gravity="right|center_vertical"
                            android:hint="••••••••"
                            android:inputType="textPassword"
                            android:textColor="#111111"
                            android:textSize="15sp" />

                        <ImageView
                            android:id="@+id/ivVisibilityNew"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentLeft="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_eye"
                            app:tint="#888888" />
                    </RelativeLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="تأكيد كلمة المرور"
                        android:textColor="#333333"
                        android:textSize="14sp"
                        android:fontFamily="@font/cairo_black"
                        android:layout_marginTop="16dp"
                        android:gravity="right" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_otp_box"
                        android:paddingHorizontal="12dp">

                        <ImageView
                            android:id="@+id/ivLockConfirm"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_lock"
                            app:tint="#888888" />

                        <EditText
                            android:id="@+id/etConfirmPassword"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_toLeftOf="@id/ivLockConfirm"
                            android:layout_toRightOf="@+id/ivVisibilityConfirm"
                            android:background="@null"
                            android:gravity="right|center_vertical"
                            android:hint="••••••••"
                            android:inputType="textPassword"
                            android:textColor="#111111"
                            android:textSize="15sp" />

                        <ImageView
                            android:id="@+id/ivVisibilityConfirm"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentLeft="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_eye"
                            app:tint="#888888" />
                    </RelativeLayout>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnSavePassword"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        app:cardCornerRadius="25dp"
                        app:cardBackgroundColor="#0069B4"
                        app:cardElevation="0dp"
                        android:layout_marginTop="24dp">

                        <RelativeLayout
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:layout_gravity="center">

                            <ImageView
                                android:id="@+id/ivArrow"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_centerVertical="true"
                                android:src="@drawable/back"
                                android:rotation="180"
                                app:tint="#FFFFFF" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_toRightOf="@id/ivArrow"
                                android:layout_centerVertical="true"
                                android:layout_marginLeft="8dp"
                                android:text="حفظ كلمة المرور"
                                android:textColor="#FFFFFF"
                                android:textSize="16sp"
                                android:fontFamily="@font/cairo_black" />
                        </RelativeLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <LinearLayout
                android:id="@+id/btnReturnToLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="28dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                app:layout_constraintTop_toBottomOf="@id/cardForm"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">



                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="6dp"
                    android:text="الرجوع لتسجيل الدخول"
                    android:textColor="#0069B4"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="@font/cairo_black" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:rotation="180"
                    android:src="@drawable/back1"
                    app:tint="#0069B4" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>