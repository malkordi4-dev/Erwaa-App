<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F7FC"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvSkip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="تخطي"
        android:textColor="#555555"
        android:textSize="16sp"
        android:fontFamily="@font/cairo_black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="8dp"/>

    <TextView
        android:id="@+id/tvTopLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="إرواء"
        android:textColor="#0D6383"
        android:textSize="20sp"
        android:fontFamily="@font/cairo_black"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="12dp"
        android:layout_marginStart="8dp"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/centerImageContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvTopLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivTruckLocation"
            android:layout_width="320dp"
            android:layout_height="320dp"
            android:src="@drawable/img1"
            android:scaleType="centerCrop"
            android:padding="8dp"
            android:background="#FFFFFF"
            app:shapeAppearanceOverlay="@style/CircleImageViewStyle"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="5dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginTop="40dp"
            android:layout_marginEnd="15dp"
            app:layout_constraintTop_toTopOf="@id/ivTruckLocation"
            app:layout_constraintEnd_toEndOf="@id/ivTruckLocation">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="سعر مراقب"
                    android:textColor="#0D6383"
                    android:textSize="13sp"
                    android:fontFamily="@font/cairo_black"
                    android:layout_marginEnd="8dp"/>

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_mylocation"
                    app:tint="#0056C6" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardFastDelivery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="5dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="60dp"
            android:layout_marginStart="15dp"
            app:layout_constraintBottom_toBottomOf="@id/ivTruckLocation"
            app:layout_constraintStart_toStartOf="@id/ivTruckLocation">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:paddingVertical="8dp">

                <View
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:background="@android:drawable/ic_menu_recent_history"
                    android:backgroundTint="#4CAF50"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="توزيع مجاني"
                    android:textColor="#0D6383"
                    android:textSize="13sp"
                    android:fontFamily="@font/cairo_black" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="مياه كافية .. وبكل الطرق"
        android:textColor="#0D6383"
        android:textSize="24sp"
        android:fontFamily="@font/cairo_black"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/centerImageContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="سواء كنت بدك تشتري مياه بأسعار مراقبة، أو بدك تعرف مواعيد وأماكن سيارات التوزيع المجاني في منطقتك، إرواء بيجمعلك كل الخيارات بمكان واحد لضمان حقك في المياه."
        android:textColor="#666666"
        android:textSize="12sp"
        android:fontFamily="@font/cairo_black"
        android:gravity="center"
        android:lineSpacingMultiplier="1.3"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/dotsIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvDescription"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.cardview.widget.CardView
            android:layout_width="8dp"
            android:layout_height="8dp"
            app:cardCornerRadius="4dp"
            app:cardBackgroundColor="#CBDCE9"
            app:cardElevation="0dp"
            android:layout_marginHorizontal="4dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="22dp"
            android:layout_height="8dp"
            app:cardCornerRadius="4dp"
            app:cardBackgroundColor="#0056C6"
            app:cardElevation="0dp"
            android:layout_marginHorizontal="4dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="8dp"
            android:layout_height="8dp"
            app:cardCornerRadius="4dp"
            app:cardBackgroundColor="#CBDCE9"
            app:cardElevation="0dp"
            android:layout_marginHorizontal="4dp"/>
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/btnStart"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        app:cardCornerRadius="28dp"
        app:cardBackgroundColor="#0056C6"
        app:cardElevation="2dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/dotsIndicator"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ابدأ  ←"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:fontFamily="@font/cairo_black"
            android:textStyle="bold"
            android:layout_gravity="center"/>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>