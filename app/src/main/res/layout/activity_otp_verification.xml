<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">
    <RelativeLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="@font/cairo_black"
            android:text="إرواء"
            android:textColor="#0069B4"
            android:textSize="18sp" />

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:src="@drawable/back"
            app:tint="#555555" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingBottom="32dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layoutAvatarContainer"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_marginTop="40dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <View
                    android:id="@+id/circle_background"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:background="@drawable/bg_circle_light_blue"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <ImageView
                    android:id="@+id/shield_icon"
                    android:layout_width="84dp"
                    android:layout_height="75dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/protection"
                    app:layout_constraintBottom_toBottomOf="@id/circle_background"
                    app:layout_constraintEnd_toEndOf="@id/circle_background"
                    app:layout_constraintStart_toStartOf="@id/circle_background"
                    app:layout_constraintTop_toTopOf="@id/circle_background" />

                <androidx.cardview.widget.CardView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    app:cardCornerRadius="13dp"
                    app:cardBackgroundColor="#0B6383"
                    app:cardElevation="2dp"
                    app:layout_constraintTop_toTopOf="@id/circle_background"
                    app:layout_constraintEnd_toEndOf="@id/circle_background"
                    android:layout_marginTop="4dp"
                    android:layout_marginEnd="4dp">

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@android:drawable/ic_lock_idle_lock"
                        android:layout_gravity="center"
                        app:tint="#FFFFFF" />
                </androidx.cardview.widget.CardView>

            </androidx.constraintlayout.widget.ConstraintLayout>
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="تفعيل الحساب"
                android:textColor="#0069B4"
                android:textSize="22sp"
                android:fontFamily="@font/cairo_black"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/layoutAvatarContainer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <LinearLayout
                android:id="@+id/layoutSub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/tvTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="059XXXXXXX"
                    android:textColor="#111111"
                    android:textSize="14sp"
                    android:fontFamily="@font/cairo_black" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="أدخل الكود المرسل إلى رقمك "
                    android:textColor="#666666"
                    android:textSize="14sp"
                    android:fontFamily="@font/cairo_regular" />
            </LinearLayout>

            <EditText
                android:id="@+id/etOtp1"
                android:layout_width="54dp"
                android:layout_height="64dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_otp_box"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textColor="#111111"
                android:textSize="22sp"
                android:fontFamily="@font/cairo_black"
                app:layout_constraintTop_toBottomOf="@id/layoutSub"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/etOtp2" />

            <EditText
                android:id="@+id/etOtp2"
                android:layout_width="54dp"
                android:layout_height="64dp"
                android:layout_marginTop="32dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_otp_box"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textColor="#111111"
                android:textSize="22sp"
                android:fontFamily="@font/cairo_black"
                app:layout_constraintTop_toBottomOf="@id/layoutSub"
                app:layout_constraintStart_toEndOf="@+id/etOtp1"
                app:layout_constraintEnd_toStartOf="@+id/etOtp3" />

            <EditText
                android:id="@+id/etOtp3"
                android:layout_width="54dp"
                android:layout_height="64dp"
                android:layout_marginTop="32dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_otp_box"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textColor="#111111"
                android:textSize="22sp"
                android:fontFamily="@font/cairo_black"
                app:layout_constraintTop_toBottomOf="@id/layoutSub"
                app:layout_constraintStart_toEndOf="@+id/etOtp2"
                app:layout_constraintEnd_toStartOf="@+id/etOtp4" />

            <EditText
                android:id="@+id/etOtp4"
                android:layout_width="54dp"
                android:layout_height="64dp"
                android:layout_marginTop="32dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_otp_box"
                android:gravity="center"
                android:inputType="number"
                android:maxLength="1"
                android:textColor="#111111"
                android:textSize="22sp"
                android:fontFamily="@font/cairo_black"
                app:layout_constraintTop_toBottomOf="@id/layoutSub"
                app:layout_constraintStart_toEndOf="@+id/etOtp3"
                app:layout_constraintEnd_toEndOf="parent" />

            <LinearLayout
                android:id="@+id/layoutTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="24dp"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/etOtp1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:56"
                    android:textColor="#0D6383"
                    android:textSize="14sp"
                    android:fontFamily="@font/cairo_black" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" إعادة الإرسال بعد "
                    android:textColor="#666666"
                    android:textSize="13sp"
                    android:fontFamily="@font/cairo_regular" />
            </LinearLayout>

            <TextView
                android:id="@+id/btnResend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="إعادة إرسال الرمز"
                android:textColor="#0069B4"
                android:textSize="13sp"
                android:fontFamily="@font/cairo_black"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/layoutTimer"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <androidx.cardview.widget.CardView
                android:id="@+id/btnVerify"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                app:cardCornerRadius="25dp"
                app:cardBackgroundColor="#0069B4"
                app:cardElevation="0dp"
                android:layout_marginTop="32dp"
                app:layout_constraintTop_toBottomOf="@id/btnResend"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="تأكيد"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:fontFamily="@font/cairo_black" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>