<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:layoutDirection="rtl">

    <RelativeLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="حالة الطلب "
            android:textColor="#0069B4"
            android:textSize="18sp" />

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:src="@drawable/back"
            app:tint="#0069B4" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/layoutHeaderAccepted"
        app:layout_constraintBottom_toTopOf="@id/layoutFooterActions">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="170dp"
                android:layout_height="170dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="28dp"
                app:cardCornerRadius="95dp"
                app:cardElevation="6dp"
                app:strokeColor="#CBD5E1"
                app:strokeWidth="2.5dp"
                app:cardBackgroundColor="#FFFFFF">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:layout_marginTop="20dp"
                    android:src="@drawable/img10" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="تم قبول طلبك بنجاح!"
                android:textColor="#0F172A"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvAcceptanceMainDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginHorizontal="8dp"
                android:text="قام المزود (محطة غزة المركزية) بالموافقة على طلبك. يرجى إتمام عملية الدفع لتأكيد الحجز وبدء التوصيل."
                android:textColor="#334155"
                android:textSize="14sp"
                android:gravity="center"
                android:lineSpacingExtra="5dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="#475569"
                app:strokeWidth="2dp">
                <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="right">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="نوع الخدمة"
                            android:textColor="#64748B"
                            android:textSize="11sp" />
                        <TextView
                            android:id="@+id/tvServiceTypeName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="توصيل مياه صالحة للشرب"
                            android:textColor="#0F172A"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:layout_width="2dp"
                        android:layout_height="36dp"
                        android:background="#475569"
                        android:layout_marginHorizontal="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="right">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="الكمية"
                            android:textColor="#64748B"
                            android:textSize="11sp" />
                        <TextView
                            android:id="@+id/tvServiceQuantityValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="500 لتر"
                            android:textColor="#0069B4"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1.5dp"
                    android:background="#CBD5E1"
                    android:layout_verticalMargin="16dp" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/ivStatusCheckIcon"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:layout_marginTop="15dp"
                        android:src="@drawable/protection"
                        app:tint="#0069B4" />

                    <TextView
                        android:id="@+id/tvPaymentStatusLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toLeftOf="@id/ivStatusCheckIcon"
                        android:layout_marginRight="8dp"
                        android:layout_marginTop="15dp"
                        android:layout_centerVertical="true"
                        android:text="حالة الطلب: بانتظار الدفع"
                        android:textColor="#0069B4"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </RelativeLayout>

            </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/layoutFooterActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#F8FAFC"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnNavigateToPayment"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="💳  الانتقال إلى الدفع"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="#0069B4"
            app:cornerRadius="12dp" />

        <Button
            android:id="@+id/btnCancelCurrentOrder"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:text="❌  إلغاء الطلب"
            android:textColor="#DC2626"
            android:textSize="14sp"
            android:textStyle="bold"
            android:backgroundTint="#FFFFFF"
            app:cornerRadius="12dp"
            android:strokeColor="#DC2626"
            app:strokeWidth="0.5dp"/>
        /> <TextView
        android:id="@+id/tvOrderSerialAndDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="رقم الطلب: ERW-98421#  •  التاريخ: 24 مايو 2026"
        android:textColor="#475569"
        android:textSize="12sp"
        android:gravity="center" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>