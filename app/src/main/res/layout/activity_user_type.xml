<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <RelativeLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="إرواء"
            android:textColor="#0D6383"
            android:textSize="20sp"
            android:fontFamily="@font/cairo_black"
            android:layout_centerInParent="true" />

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:src="@drawable/back"
            app:tint="#555555" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingBottom="24dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardLogoIcon"
                android:layout_width="60dp"
                android:layout_height="60dp"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="#0069B4"
                app:cardElevation="0dp"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_water_drop"
                    app:tint="#FFFFFF" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="كيف ترغب في استخدام إرواء؟"
                android:textColor="#111111"
                android:textSize="20sp"
                android:fontFamily="@font/cairo_black"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/cardLogoIcon"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="اختر نوع حسابك لنتمكن من توفير أفضل تجربة مخصصة لاحتياجاتك في إدارة الموارد المائية."
                android:textColor="#777777"
                android:textSize="13sp"
                android:gravity="center"
                android:fontFamily="@font/cairo_regular"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/tvTitle" />

            <androidx.cardview.widget.CardView
                android:id="@+id/cardClient"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginTop="32dp"
                app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:padding="20dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        app:cardCornerRadius="32dp"
                        app:cardBackgroundColor="#EDF2F7"
                        app:cardElevation="0dp">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/home"
                            android:layout_gravity="center"
                            app:tint="#0A5A7A"/>
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="طالب خدمة (مواطن)"
                        android:textColor="#111111"
                        android:textSize="16sp"
                        android:fontFamily="@font/cairo_black"
                        android:layout_marginTop="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="أريد الحصول على المياه لمنزلي، متابعة عداداتي، وتقديم طلبات الصيانة بسهولة."
                        android:textColor="#888888"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:fontFamily="@font/cairo_regular"
                        android:layout_marginTop="6dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardProvider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/cardClient">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:padding="20dp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        app:cardCornerRadius="32dp"
                        app:cardBackgroundColor="#EDF2F7"
                        app:cardElevation="0dp">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="34dp"
                            android:layout_gravity="center"
                            android:src="@drawable/truck"
                            app:tint="#0A5A7A" />
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="مقدم خدمة (صاحب بئر/صهريج)"
                        android:textColor="#111111"
                        android:textSize="16sp"
                        android:fontFamily="@font/cairo_black"
                        android:layout_marginTop="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="أمتلك بئراً أو صهريجاً وأرغب في إدارة طلبات التوصيل وتوسيع نطاق خدمتي للمجتمع."
                        android:textColor="#888888"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:fontFamily="@font/cairo_regular"
                        android:layout_marginTop="6dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/btnNext"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                app:cardCornerRadius="25dp"
                app:cardBackgroundColor="#E2E8F0"
                app:cardElevation="0dp"
                android:layout_marginTop="36dp"
                app:layout_constraintTop_toBottomOf="@id/cardProvider">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="المتابعة"
                    android:textColor="#A0AEC0"
                    android:textSize="15sp"
                    android:fontFamily="@font/cairo_black"
                    android:layout_gravity="center"/>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="يمكنك تغيير نوع الحساب لاحقاً من الإعدادات"
                android:textColor="#777777"
                android:textSize="12sp"
                android:fontFamily="@font/cairo_regular"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/btnNext"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>