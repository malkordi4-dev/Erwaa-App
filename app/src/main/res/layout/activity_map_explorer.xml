<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layoutDirection="rtl">

    <!-- واجهة الخريطة والعناصر العلوية -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <org.osmdroid.views.MapView
            android:id="@+id/map"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- صندوق البحث -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSearch"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginTop="24dp"
            android:layout_marginHorizontal="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:strokeWidth="0dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingHorizontal="16dp">
                <ImageView
                    android:id="@+id/move22"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/menu"
                    app:tint="#0069B4"/>
                <ImageView
                    android:id="@+id/ivSearch"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_alignParentLeft="true"
                    android:layout_centerVertical="true"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="#0D6383"/>
                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="بحث عن منطقة أو نقطة توزيع..."
                    android:textColor="#999999"
                    android:textSize="14sp"
                    android:layout_toRightOf="@id/ivSearch"
                    android:layout_toLeftOf="@id/move22"
                    android:layout_centerVertical="true"
                    android:gravity="right"
                    android:background="@android:color/transparent"
                    android:layout_marginHorizontal="8dp"
                    android:imeOptions="actionSearch"
                    android:inputType="text"/>
            </RelativeLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- أزرار الفلترة الجانبية -->
        <LinearLayout
            android:id="@+id/sidebarFilters"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toBottomOf="@id/cardSearch"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:gravity="center"
            android:elevation="8dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnFilterWell"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="25dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF"
                android:clickable="true"
                android:focusable="true"
                app:strokeWidth="0dp">
                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:src="@drawable/water"
                    app:tint="#0069B4"/>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnFilterTruck"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="25dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF"
                android:clickable="true"
                android:focusable="true"
                app:strokeWidth="0dp">
                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:src="@drawable/truck"
                    app:tint="#0069B4"/>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnFilterStorage"
                android:layout_width="50dp"
                android:layout_height="50dp"
                app:cardCornerRadius="25dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF"
                android:clickable="true"
                android:focusable="true"
                app:strokeWidth="0dp">
                <ImageView
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:src="@drawable/barrel"
                    app:tint="#0069B4"/>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>


        <!-- أزرار التحكم بالخريطة -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="24dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnZoomIn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:src="@android:drawable/ic_input_add"
                app:fabSize="mini"
                app:backgroundTint="#FFFFFF"
                tools:ignore="ContentDescription" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnZoomOut"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:src="@android:drawable/ic_input_delete"
                app:fabSize="mini"
                app:backgroundTint="#FFFFFF"
                tools:ignore="ContentDescription" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnMyLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@android:drawable/ic_menu_mylocation"
                app:fabSize="mini"
                app:backgroundTint="#FFFFFF"
                tools:ignore="ContentDescription" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- البطاقة السفلية (Bottom Sheet) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomSheetCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="32dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="#FFFFFF"
        app:strokeWidth="0dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="12dp"
            android:paddingBottom="20dp"
            android:gravity="center_horizontal">

            <View
                android:layout_width="50dp"
                android:layout_height="4dp"
                android:background="#DBDBDB"
                android:layout_marginBottom="16dp"/>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardPinIcon"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    app:cardCornerRadius="10dp"
                    app:cardBackgroundColor="#E6F0F6"
                    app:cardElevation="0dp"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@android:drawable/ic_menu_compass"
                        android:layout_gravity="center"
                        app:tint="#0056C6"/>
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentLeft="true"
                    android:layout_toLeftOf="@id/cardPinIcon"
                    android:gravity="right"
                    android:layout_marginRight="12dp">

                    <TextView
                        android:id="@+id/tvLocationTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="موقع التوصيل المحدد"
                        android:textColor="#0D6383"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvLocationAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="حي الرمال، غزة"
                        android:textColor="#777777"
                        android:textSize="13sp"
                        android:gravity="right"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </RelativeLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/btnConfirm"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                app:cardCornerRadius="27dp"
                app:cardBackgroundColor="#0056C6"
                app:cardElevation="2dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:id="@+id/tvNear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="تأكيد الموقع والبدء"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_gravity="center"/>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/login"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="يجب تسجيل الدخول لإتمام الطلب"
                android:textColor="#E53935"
                android:textSize="12sp"
                android:background="#FFEBEE"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>