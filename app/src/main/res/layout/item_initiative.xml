<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="16dp"
    app:cardElevation="1dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E2E8F0"
    android:layoutDirection="rtl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentRight="true">

                <TextView
                    android:id="@+id/tv_initiative_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="حي الرمال - سقيا 4"
                    android:textColor="#1E293B"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tv_initiative_location"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="غزة، الرمال الشمالي"
                    android:textColor="#64748B"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/badge_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentLeft="true"
                app:cardBackgroundColor="#CCFBF1"
                app:cardCornerRadius="20dp"
                app:strokeWidth="0dp">

                <TextView
                    android:id="@+id/tv_status_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="قيد التمويل"
                    android:textColor="#0D9488"
                    android:textSize="12sp"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:textStyle="bold"/>
            </com.google.android.material.card.MaterialCardView>
        </RelativeLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <TextView
                android:id="@+id/tv_target_volume"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true"
                android:text="الهدف: 50,000 لتر"
                android:textColor="#475569"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tv_progress_percentage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentLeft="true"
                android:text="65% مكتمل"
                android:textColor="#0069B4"
                android:textSize="13sp"
                android:textStyle="bold"/>
        </RelativeLayout>

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progress_bar_initiative"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:progress="65"
            app:trackColor="#E2E8F0"
            app:indicatorColor="#0069B4"
            app:trackCornerRadius="4dp"
            app:trackThickness="8dp"/>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_track_progress"
                style="@style/Widget.Material3.Button.Filled"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_alignParentRight="true"
                android:text="تتبع التقدم"
                android:textSize="12sp"
                android:backgroundTint="#0069B4"
                app:cornerRadius="8dp"
                app:insetTop="0dp"
                app:insetBottom="0dp"/>

            <TextView
                android:id="@+id/tv_footer_note"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true"
                android:text="التوزيع جاري عبر الشركاء"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:visibility="gone"/>
        </RelativeLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>