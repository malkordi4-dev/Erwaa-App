<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:layoutDirection="rtl">

    <RelativeLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="اختر خدمتك"
            android:textColor="#0D6383"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_centerInParent="true" />

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:src="@drawable/back"
            app:tint="#0D6383" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader"
        app:layout_constraintBottom_toTopOf="@id/bottomNavServices">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/img5"
                        android:scaleType="centerCrop" />
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#4D000000" />
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardSingleOrder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#0D63B3"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">
                    <androidx.cardview.widget.CardView
                        android:id="@+id/iconContainerFlash"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        app:cardBackgroundColor="#22FFFFFF"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0dp"
                        android:layout_alignParentStart="true"
                        android:layout_alignParentTop="true">
                        <ImageView
                            android:id="@+id/ivFlashIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/flash"
                            app:tint="#FFFFFF" />
                    </androidx.cardview.widget.CardView>
                    <androidx.cardview.widget.CardView
                        android:id="@+id/tagContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:cardBackgroundColor="#E0F2FE"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="@id/iconContainerFlash">
                        <TextView
                            android:id="@+id/tagMostRequested"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="الأكثر طلباً"
                            android:textColor="#0D63B3"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="5dp" />
                    </androidx.cardview.widget.CardView>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_below="@id/iconContainerFlash"
                        android:layout_marginTop="20dp">
                        <TextView
                            android:id="@+id/tvSingleOrderTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="طلب فردي سريع"
                            android:textColor="#FFFFFF"
                            android:textSize="16sp" />
                        <TextView
                            android:id="@+id/tvSingleOrderDesc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="توصيل فوري ومباشر لخزان منزلك خلال ساعات قليلة."
                            android:textColor="#93C5FD"
                            android:textSize="12sp"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardMonthlySubscription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="14dp"
                app:cardElevation="1dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">
                    <androidx.cardview.widget.CardView
                        android:id="@+id/iconContainer1"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        app:cardBackgroundColor="#E0F7FA"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0dp"
                        android:layout_alignParentStart="true">
                        <ImageView
                            android:id="@+id/ivCalendarIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_my_calendar"
                            app:tint="#0284C7" />
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:id="@+id/tvMonthlySubscriptionTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="اشتراك شهري"
                        android:textColor="#1E293B"
                        android:textSize="16sp"
                        android:layout_toEndOf="@id/iconContainer1"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="12dp" />
                    <TextView
                        android:id="@+id/tvMonthlySubscriptionNote"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🛡️ وفّر حتى 15% شهرياً"
                        android:textColor="#059669"
                        android:textSize="12sp"
                        android:layout_alignParentEnd="true"
                        android:layout_marginTop="50dp" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/cardGroupInitiative"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="14dp"
                app:cardElevation="1dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">
                    <androidx.cardview.widget.CardView
                        android:id="@+id/iconContainer2"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        app:cardBackgroundColor="#E0F2FE"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0dp"
                        android:layout_alignParentStart="true">
                        <ImageView
                            android:id="@+id/ivGroupIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@android:drawable/ic_menu_share"
                            app:tint="#0284C7" />
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:id="@+id/tvGroupInitiativeTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="مبادرة جماعية"
                        android:textColor="#1E293B"
                        android:textSize="16sp"
                        android:layout_toEndOf="@id/iconContainer2"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="12dp" />
                    <TextView
                        android:id="@+id/tvGroupInitiativeNote"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏷️ خصومات للأحياء السكنية"
                        android:textColor="#0284C7"
                        android:textSize="12sp"
                        android:layout_alignParentEnd="true"
                        android:layout_marginTop="50dp" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="نسّق مع جيرانك في الحي للحصول على سعر مخفّض وتوصيل موحّد."
                android:textColor="#64748B"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginBottom="24dp" />
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation Bar -->
    <LinearLayout
        android:id="@+id/bottomNavServices"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/user"
                app:tint="#94A3B8" />
            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="حسابي"
                android:textColor="#94A3B8"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navWallet"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/wallet"
                app:tint="#94A3B8" />
            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="المحفظة"
                android:textColor="#94A3B8"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navOrders"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/personal"
                app:tint="#94A3B8" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="طلباتي"
                android:textColor="#94A3B8"
                android:textSize="11sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/home"
                app:tint="#94A3B8" />
            <TextView android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="الرئيسية"
                android:textColor="#94A3B8"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
