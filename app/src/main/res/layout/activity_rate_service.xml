<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:layoutDirection="rtl">

    <RelativeLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="#FFFFFF"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:src="@drawable/back"
            app:tint="#0056C6" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="تقييم الخدمة"
            android:textColor="#0056C6"
            android:textSize="17sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeColor="#E2E8F0"
                app:strokeWidth="1dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/tagOrderNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        app:cardBackgroundColor="#D2E6F7"
                        app:cardCornerRadius="6dp"
                        app:cardElevation="0dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent">
                        <TextView
                            android:id="@+id/tvOrderNumber"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="#ORD-8821"
                            android:textColor="#0056C6"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:layout_gravity="center"
                            android:paddingHorizontal="10dp"/>
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/tvStationName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="محطة مياه النصر المركزية"
                        android:textColor="#1E293B"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:gravity="left"
                        android:layout_marginStart="12dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/tagOrderNumber" />

                    <TextView
                        android:id="@+id/tvOrderDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📅 24 مايو 2024"
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"
                        app:layout_constraintTop_toBottomOf="@id/tvStationName"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <View
                        android:id="@+id/dividerCard"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F1F5F9"
                        android:layout_marginTop="16dp"
                        app:layout_constraintTop_toBottomOf="@id/tvOrderDate"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginTop="12dp"
                        app:layout_constraintTop_toBottomOf="@id/dividerCard"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/dividerVertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="الحجم"
                            android:textColor="#94A3B8"
                            android:textSize="11sp" />
                        <TextView
                            android:id="@+id/tvQuantity"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="20 لتر"
                            android:textColor="#0A3A60"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <View
                        android:id="@+id/dividerVertical"
                        android:layout_width="1dp"
                        android:layout_height="32dp"
                        android:background="#E2E8F0"
                        android:layout_marginTop="16dp"
                        app:layout_constraintTop_toBottomOf="@id/dividerCard"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginTop="12dp"
                        app:layout_constraintTop_toBottomOf="@id/dividerCard"
                        app:layout_constraintStart_toEndOf="@id/dividerVertical"
                        app:layout_constraintEnd_toEndOf="parent">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="السعر"
                            android:textColor="#94A3B8"
                            android:textSize="11sp" />
                        <TextView
                            android:id="@+id/tvPrice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="15.00 ₪"
                            android:textColor="#0A3A60"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="كيف كانت تجربتك؟"
                android:textColor="#0A3A60"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_gravity="center_horizontal" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="رأيك يساعدنا في تحسين جودة خدماتنا للسكان"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:layout_marginTop="6dp"
                android:layout_gravity="center_horizontal" />

            <RatingBar
                android:id="@+id/ratingBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:numStars="5"
                android:stepSize="1"
                android:rating="0"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="28dp"
                android:layout_gravity="center_horizontal"
                style="@android:style/Widget.Material.RatingBar" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ملاحظات إضافية (اختياري)"
                android:textColor="#475569"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etNotes"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="@drawable/bg_edit_text_rounded"
                android:gravity="top|right"
                android:hint="اكتب ملاحظاتك هنا (سرعة التوصيل، جودة المياه، التعامل...)"
                android:textColorHint="#94A3B8"
                android:textColor="#1E293B"
                android:textSize="13sp"
                android:padding="14dp"
                android:inputType="textMultiLine"
                android:layout_marginBottom="24dp"/>

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivWaterRipple"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:src="@drawable/img16"
                android:scaleType="centerCrop"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="32dp"
                app:shapeAppearanceOverlay="@style/CircleImage" />

            <LinearLayout
                android:id="@+id/btnSubmitRating"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/bg_primary_button_rounded"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="إرسال التقييم"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="8dp"
                    android:scaleX="-1"
                    android:src="@android:drawable/ic_menu_send"
                    app:tint="#FFFFFF" />

            </LinearLayout>
            <LinearLayout
                android:id="@+id/btnSkip"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="تخطي"
                    android:textColor="#0056C6"
                    android:textSize="14sp"
                    android:textStyle="bold" />



            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
