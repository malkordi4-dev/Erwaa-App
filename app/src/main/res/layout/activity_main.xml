<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F7FC">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/centerDesignContainer"
        android:layout_width="320dp"
        android:layout_height="320dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/logoContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/circle_thin_border"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <View
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:background="@drawable/circle_thin_border"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <View
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:background="@drawable/circle_thin_border"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <View
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:background="@drawable/circle_dashed_border"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:layout_width="50dp"
            android:layout_height="65dp"
            android:src="@drawable/ic_water_drop"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/logoContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="35dp"
        app:layout_constraintTop_toBottomOf="@id/centerDesignContainer"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvArabicLogo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="إرواء"
            android:textColor="#0069B4"
            android:textSize="70sp"
            android:fontFamily="@font/cairo_black"
            android:textStyle="bold"
            android:includeFontPadding="false" />

        <TextView
            android:id="@+id/tvEnglishLogo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ERWAA"
            android:textColor="#0069B4"
            android:textSize="18sp"
            android:fontFamily="@font/cairo_black"
            android:textStyle="bold"
            android:letterSpacing="0.4"
            android:layout_marginTop="-8dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>