<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:layoutDirection="rtl">

    <RelativeLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="طلب مياه فردي"
            android:textColor="#0069B4"
            android:textSize="18sp" />

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:src="@drawable/back"
            app:tint="#0069B4" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader"
        app:layout_constraintBottom_toTopOf="@id/btnSubmitOrder">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Progress Steps (Skip for brevity) -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💧 تحديد الكمية"
                android:textColor="#1E293B"
                android:textSize="18sp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/btnByLiter"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardBackgroundColor="#BAE6FD"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="باللتر"
                        android:textColor="#0C4A6E"
                        android:textSize="17sp"
                        android:layout_gravity="center" />
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/btnByTank"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardBackgroundColor="#FFFFFF"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="1dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="بعدد الخزانات"
                        android:textColor="#64748B"
                        android:textSize="17sp"
                        android:layout_gravity="center" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="#E0F2FE"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingHorizontal="16dp">
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnMinus"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_centerVertical="true"
                        app:cardCornerRadius="18dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:textSize="20sp" android:layout_gravity="center" />
                    </androidx.cardview.widget.CardView>
                    <TextView
                        android:id="@+id/tvQuantityCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="500"
                        android:textColor="#0D63B3"
                        android:textSize="22sp"
                        android:layout_centerInParent="true" />
                    <TextView
                        android:id="@+id/tvUnit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="لتر"
                        android:layout_toLeftOf="@id/tvQuantityCount"
                        android:layout_marginRight="8dp"
                        android:layout_centerVertical="true" />
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnPlus"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_centerVertical="true"
                        android:layout_alignParentLeft="true"
                        app:cardCornerRadius="18dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+" android:textSize="20sp" android:layout_gravity="center" />
                    </androidx.cardview.widget.CardView>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📍 موقع التوصيل"
                android:textColor="#1E293B"
                android:textSize="18sp"
                android:layout_marginBottom="12dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp">
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- استبدال MapView بـ Osmdroid -->
                    <org.osmdroid.views.MapView
                        android:id="@+id/mapView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnLocateMe"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_gravity="bottom|left"
                        android:layout_margin="12dp"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎯 تحديد موقعي"
                            android:textColor="#1E293B"
                            android:textSize="13sp"
                            android:paddingHorizontal="12dp"
                            android:layout_gravity="center" />
                    </androidx.cardview.widget.CardView>
                </FrameLayout>
            </androidx.cardview.widget.CardView>

            <EditText
                android:id="@+id/etAddressDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="تفاصيل العنوان (شارع، معلم بارز...)"
                android:padding="12dp"
                android:background="@drawable/bg_input_field"
                android:layout_marginBottom="16dp"/>

            <EditText
                android:id="@+id/etNotes"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:hint="ملاحظات إضافية..."
                android:padding="12dp"
                android:gravity="top"
                android:background="@drawable/bg_input_field"
                android:layout_marginBottom="16dp"/>

        </LinearLayout>
    </ScrollView>

    <androidx.cardview.widget.CardView
        android:id="@+id/btnSubmitOrder"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_margin="16dp"
        app:cardBackgroundColor="#005B8A"
        app:cardCornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="استمرار للمراجعة"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
