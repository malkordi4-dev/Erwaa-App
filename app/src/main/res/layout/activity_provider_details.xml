<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:layoutDirection="rtl">

    <RelativeLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp"
        android:background="#FFFFFF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="@font/cairo_black"
            android:text="تفاصيل المزود"
            android:textColor="#0069B4"
            android:textSize="18sp" />

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:src="@drawable/back"
            app:tint="#555555" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="220dp">

                <ImageView
                    android:id="@+id/ivProviderImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/img4"
                    android:scaleType="centerCrop"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#1A000000"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_gravity="bottom"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="نشط الآن"
                        android:textColor="#FFFFFF"
                        android:background="#22D3EE"
                        android:textSize="11sp"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="2dp"
                        android:layout_marginBottom="4dp"
                        android:fontFamily="@font/cairo_regular"/>

                    <TextView
                        android:id="@+id/tvProviderName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="بئر الهدى المركزي"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/cairo_black"/>

                    <TextView
                        android:id="@+id/tvLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="حي الرمال، غزة"
                        android:textColor="#E2E8F0"
                        android:textSize="13sp"
                        android:fontFamily="@font/cairo_regular"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="1dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="16dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_toStartOf="@id/ivWaterIcon"
                                android:layout_alignParentStart="true">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="سعة الخزان"
                                    android:textColor="#64748B"
                                    android:textSize="11sp"
                                    android:fontFamily="@font/cairo_regular"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="5,000 لتر"
                                    android:textColor="#1E293B"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    android:fontFamily="@font/cairo_black"/>
                            </LinearLayout>

                            <ImageView
                                android:id="@+id/ivWaterIcon"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/water"
                                app:tint="#0D63B3"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"/>
                        </RelativeLayout>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="1dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="16dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_toStartOf="@id/ivHoseIcon"
                                android:layout_alignParentStart="true">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="طول الخرطوم"
                                    android:textColor="#64748B"
                                    android:textSize="11sp"
                                    android:fontFamily="@font/cairo_regular"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="45 متر"
                                    android:textColor="#1E293B"
                                    android:textSize="15sp"
                                    android:textStyle="bold"
                                    android:fontFamily="@font/cairo_black"/>
                            </LinearLayout>

                            <ImageView
                                android:id="@+id/ivHoseIcon"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@android:drawable/ic_menu_sort_by_size"
                                app:tint="#0D63B3"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"/>
                        </RelativeLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_toStartOf="@id/ivPumpIcon"
                            android:layout_alignParentStart="true">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="نوع المضخة"
                                android:textColor="#64748B"
                                android:textSize="11sp"
                                android:fontFamily="@font/cairo_regular"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="تيربو هيدروليك"
                                android:textColor="#1E293B"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/cairo_black"/>
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/ivPumpIcon"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_manage"
                            app:tint="#0D63B3"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"/>
                    </RelativeLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/ic_menu_recent_history"
                                app:tint="#0D63B3"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ساعات العمل"
                                android:textColor="#1E293B"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_marginStart="8dp"
                                android:fontFamily="@font/cairo_black"/>
                        </LinearLayout>

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="السبت - الخميس"
                                android:textColor="#64748B"
                                android:fontFamily="@font/cairo_regular"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="07:00 ص - 10:00 م"
                                android:textColor="#1E293B"
                                android:layout_alignParentEnd="true"
                                android:fontFamily="@font/cairo_regular"/>
                        </RelativeLayout>

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="الجمعة"
                                android:textColor="#64748B"
                                android:fontFamily="@font/cairo_regular"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="01:00 م - 09:00 م"
                                android:textColor="#1E293B"
                                android:layout_alignParentEnd="true"
                                android:fontFamily="@font/cairo_regular"/>
                        </RelativeLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:layout_marginTop="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp">
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <fragment
                            android:id="@+id/mapFragment"
                            android:name="com.google.android.gms.maps.SupportMapFragment"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />

                        <Button
                            android:id="@+id/btnOpenMap"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:layout_gravity="bottom|start"
                            android:layout_margin="12dp"
                            android:backgroundTint="#0D63B3"
                            android:text="فتح الخريطة"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:paddingHorizontal="12dp"
                            android:fontFamily="@font/cairo_regular"/>
                    </FrameLayout>
                </androidx.cardview.widget.CardView>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp">
                    <TextView
                        android:id="@+id/tvReviewsTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="آراء المستخدمين"
                        android:textColor="#1E293B"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/cairo_black"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4.8 ⭐⭐⭐⭐⭐ (124 تقييم)"
                        android:textColor="#64748B"
                        android:textSize="12sp"
                        android:layout_alignParentEnd="true"
                        android:fontFamily="@font/cairo_regular"/>
                </RelativeLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:scrollbars="none">
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <androidx.cardview.widget.CardView
                            android:layout_width="260dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="1dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="12dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="محمد أحمد"
                                    android:textColor="#1E293B"
                                    android:textStyle="bold"
                                    android:textSize="13sp"
                                    android:fontFamily="@font/cairo_black"/>
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="خدمة ممتازة وسريعة جداً، المياه نظيفة جداً والتعامل راقي..."
                                    android:textColor="#64748B"
                                    android:textSize="12sp"
                                    android:layout_marginTop="4dp"
                                    android:fontFamily="@font/cairo_regular"/>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>

                        <androidx.cardview.widget.CardView
                            android:layout_width="260dp"
                            android:layout_height="wrap_content"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="1dp">
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="12dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="سارة محمود"
                                    android:textColor="#1E293B"
                                    android:textStyle="bold"
                                    android:textSize="13sp"
                                    android:fontFamily="@font/cairo_black"/>
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="جيد جداً، الالتزام بالوقت كان ممتازاً والسعر مناسب مقارنة بالباقي."
                                    android:textColor="#64748B"
                                    android:textSize="12sp"
                                    android:layout_marginTop="4dp"
                                    android:fontFamily="@font/cairo_regular"/>
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutBottomBar"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="السعر التقريبي"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:fontFamily="@font/cairo_regular"/>
            <TextView
                android:id="@+id/tvPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="45 شيكل / كوب"
                android:textColor="#0D63B3"
                android:textSize="16sp"
                android:textStyle="bold"
                android:fontFamily="@font/cairo_black"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnSelectService"
            android:layout_width="160dp"
            android:layout_height="48dp"
            android:text="اختر هذه الخدمة 🛒"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#0D63B3"
            android:fontFamily="@font/cairo_black"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>